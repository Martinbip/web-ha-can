{
  "kind": "collectionType",
  "collectionName": "pricing_packages",
  "info": {
    "singularName": "pricing-package",
    "pluralName": "pricing-packages",
    "displayName": "Giá Kim Loại Thị Trường",
    "description": "Bảng giá kim loại thị trường cập nhật theo LME và nội địa"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "metal": {
      "type": "string",
      "required": true
    },
    "lme_price": {
      "type": "string"
    },
    "domestic_price": {
      "type": "string"
    },
    "unit": {
      "type": "string",
      "default": "/kg"
    },
    "change": {
      "type": "string"
    },
    "trend": {
      "type": "enumeration",
      "enum": [
        "up",
        "down"
      ]
    },
    "updated": {
      "type": "string"
    }
  }
}
